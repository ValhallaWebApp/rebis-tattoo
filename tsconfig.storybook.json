{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "types": [
      "node"
    ],
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    ".storybook/**/*.ts",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/**/*.stories.mdx"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "e2e/**"
  ]
}